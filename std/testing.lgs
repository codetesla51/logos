let passed = 0
let failed = 0
let total = 0
let suiteName = ""
let assert = fn(name, got, expected) {
    total = total + 1
    if toStr(got) == toStr(expected) {
        passed = passed + 1
    } else {
        print(colorRed("--- FAIL: ") + name + " (got=" + toStr(got) + " expected=" + toStr(expected) + ")")
        failed = failed + 1
    }
}
let suite = fn(name, func) {
    suiteName = name
    func()
}
let summary = fn() {
    if failed > 0 {
        print(colorRed("FAIL"))
        print(colorRed("failed: ") + toStr(failed) + "/" + toStr(total))
        exit(1)
    } else {
        print(colorGreen("ok") + "    " + suiteName + "    " + toStr(total) + " tests passed")
    }
}
